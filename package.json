{
  "name": "so-bridge",
  "version": "0.1.0",
  "description": "Local bridge connecting IM bots (Slack, Lark) to AI coding assistants with a browser-based admin console",
  "main": "dist/index.js",
  "bin": {
    "so-bridge": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:admin": "vitest run tests/admin/",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "dotenv": "^17.3.1",
    "env-paths": "^3.0.0",
    "express": "^4.21.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
